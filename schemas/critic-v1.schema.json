{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-loop.invalid/schemas/critic-v1.schema.json",
  "title": "agent-loop critic output v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["review"],
  "properties": {
    "review": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "verdict",
            "summary",
            "blocked_reason",
            "blocking_findings",
            "non_blocking_findings"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "verdict": { "const": "LGTM" },
            "summary": { "type": "string", "minLength": 1, "maxLength": 32768 },
            "blocked_reason": { "type": "null" },
            "blocking_findings": {
              "type": "array",
              "maxItems": 0,
              "items": { "$ref": "#/definitions/finding" }
            },
            "non_blocking_findings": {
              "type": "array",
              "maxItems": 128,
              "items": { "$ref": "#/definitions/finding" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "verdict",
            "summary",
            "blocked_reason",
            "blocking_findings",
            "non_blocking_findings"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "verdict": { "const": "REVISE" },
            "summary": { "type": "string", "minLength": 1, "maxLength": 32768 },
            "blocked_reason": { "type": "null" },
            "blocking_findings": {
              "type": "array",
              "minItems": 1,
              "maxItems": 128,
              "items": { "$ref": "#/definitions/finding" }
            },
            "non_blocking_findings": {
              "type": "array",
              "maxItems": 128,
              "items": { "$ref": "#/definitions/finding" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "verdict",
            "summary",
            "blocked_reason",
            "blocking_findings",
            "non_blocking_findings"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "verdict": { "const": "BLOCKED" },
            "summary": { "type": "string", "minLength": 1, "maxLength": 32768 },
            "blocked_reason": {
              "type": "string",
              "minLength": 1,
              "maxLength": 32768,
              "pattern": "\\S"
            },
            "blocking_findings": {
              "type": "array",
              "maxItems": 0,
              "items": { "$ref": "#/definitions/finding" }
            },
            "non_blocking_findings": {
              "type": "array",
              "maxItems": 128,
              "items": { "$ref": "#/definitions/finding" }
            }
          }
        }
      ]
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "category",
        "file",
        "symbol",
        "line_start",
        "line_end",
        "problem",
        "evidence",
        "required_fix"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,63}$" },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "category": {
          "enum": [
            "correctness",
            "security",
            "reliability",
            "performance",
            "maintainability",
            "testing",
            "spec_compliance"
          ]
        },
        "file": { "type": ["string", "null"], "maxLength": 32768 },
        "symbol": { "type": ["string", "null"], "maxLength": 32768 },
        "line_start": { "type": ["integer", "null"], "minimum": 1 },
        "line_end": { "type": ["integer", "null"], "minimum": 1 },
        "problem": { "type": "string", "minLength": 1, "maxLength": 32768 },
        "evidence": { "type": "string", "minLength": 1, "maxLength": 32768 },
        "required_fix": { "type": "string", "minLength": 1, "maxLength": 32768 }
      }
    }
  }
}
